{
  "name": "lupos-bot",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "dist/boot.js",
  "imports": {
    "#root/*": "./dist/*"
  },
  "scripts": {
    "dev": "tsx src/boot.ts mode=messages",
    "clone:messages": "tsx src/boot.ts mode=clone:messages",
    "rescrape:channels": "tsx src/boot.ts mode=rescrape:channels",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.ts\"",
    "format:check": "prettier --check \"**/*.ts\"",
    "deploy": "bash deploy.sh",
    "deploy:dry": "bash deploy.sh --dry-run",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "start": "node dist/boot.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.2",
    "@distube/ytdl-core": "^4.16.12",
    "@rodrigo-barraza/utilities-library": "git+https://github.com/rodrigo-barraza/utilities-library.git",
    "discord.js": "^14.26.4",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "hex-color-to-color-name": "^2.0.1",
    "jimp": "^1.6.1",
    "luxon": "^3.7.2",
    "minio": "^8.0.7",
    "mongodb": "^7.2.0",
    "opusscript": "^0.1.1",
    "play-dl": "^1.9.7",
    "prism-media": "^1.3.5",
    "puppeteer": "^24.43.0",
    "puppeteer-core": "^24.43.0",
    "sharp": "^0.34.5",
    "xml2js": "^0.6.2",
    "youtube-transcript": "^1.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express": "^5.0.6",
    "@types/node": "^25.8.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "ts-morph": "^28.0.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.33.0",
    "vitest": "^4.1.5"
  }
}
